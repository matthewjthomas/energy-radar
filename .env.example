# ---- Home Assistant ----
# Base URL of your Home Assistant instance, e.g. http://homeassistant.local:8123
HA_URL=http://homeassistant.local:8123
# Long-Lived Access Token created under your HA profile > Security
HA_TOKEN=changeme

# ---- Database (TimescaleDB / Postgres) ----
POSTGRES_USER=energyradar
POSTGRES_PASSWORD=changeme
POSTGRES_DB=energyradar
# Matches the "db" service name in docker-compose.yml
DATABASE_URL=postgresql+asyncpg://energyradar:changeme@db:5432/energyradar

# ---- App ----
# Port the FastAPI app listens on inside the container
APP_PORT=8000
# How often (minutes) to poll Home Assistant for new readings
HA_POLL_INTERVAL_MINUTES=15
# How often (hours) to refresh the weather forecast
WEATHER_FORECAST_INTERVAL_HOURS=3
# Timezone used for day-boundary calculations (IANA name)
APP_TIMEZONE=America/New_York
# How many days back to backfill via Home Assistant's long-term statistics the
# first time a new entity is mapped (stats are retained far longer than raw
# history, so this can safely be a year+)
HA_STATS_LOOKBACK_DAYS=395
